    <div class="tier-journey-header">
      <h3 class="tier-journey-title" id="tier-journey-heading">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
          <polyline points="17 6 23 6 23 12"></polyline>
        </svg>
        Your Tier Progress
      </h3>
      <span id="current-tier-badge" class="tier-current-badge">Bronze</span>
    </div>

    <div class="points-rail">
      <div
        class="tier-rail"
        data-spend="{% if customer %}{{ customer.total_spent | money_without_currency | replace: ',', '' | replace: '$', '' }}{% else %}0{% endif %}"
      >
        <!-- Current spend indicator (positioned above the rail) -->
        <div id="tier-spend-indicator" class="tier-spend-indicator" style="left:0%;">
          <span class="spend-amount">$0</span>
          <span class="spend-arrow"></span>
        </div>

        <div class="rail" aria-hidden="true">
          <div id="tier-progress-fill" class="rail-fill" style="width:0%;"></div>

          <!-- Marks from tier blocks -->
          {%- for block in tiers -%}
            <div class="tier-mark" data-threshold="{{ block.settings.spend_threshold | default: 0 }}">
              <span class="tick-dot"></span>
              <div class="tier-meta">
                <div class="tier-amount">${{ block.settings.spend_threshold }}</div>
                <div class="tier-name-sm">{{ block.settings.name | escape }}</div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>

