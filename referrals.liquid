.reward-copy-btn {
  padding: 10px; background: white;
  border: 1px solid #ddd; border-radius: 4px;
  cursor: pointer; display: flex;
  align-items: center; justify-content: center;
  transition: all 0.2s ease;
}
.reward-copy-btn:hover { background: #f0f0f0; }
.reward-copy-btn.copied { background: var(--success); border-color: var(--success); }
.reward-copy-btn.copied svg { stroke: white; }
.reward-cancel-link {
  background: none; border: none; color: #999;
  font-size: 12px; text-decoration: underline;
  cursor: pointer; padding: 0;
}
.reward-cancel-link:hover { color: var(--primary); }
.no-rewards-message {
  text-align: center; padding: 24px;
  color: #999; font-size: 14px;
}
.reward-status-badge {
  font-size: 10px; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.05em;
  padding: 3px 8px; border-radius: 10px; margin-left: auto;
}
.reward-status-badge.active { background: #e6f7ed; color: var(--success); }
.reward-status-badge.used { background: #f0f0f0; color: #999; }
@media (max-width: 600px) {
  .rewards-grid { grid-template-columns: 1fr; }
  .your-rewards-section { padding: 20px 16px; }
}

