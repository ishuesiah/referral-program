  updateTierProgressRail();

  /* ---------- Birthday functionality ---------- */
  const birthdayBtn = document.getElementById('birthday-btn');
  const birthdayModal = document.getElementById('birthday-modal');
  const birthdayClose = document.getElementById('birthday-modal-close');
  const birthdayCancel = document.getElementById('birthday-cancel');
  const birthdaySave = document.getElementById('birthday-save');
  const birthdayMonth = document.getElementById('birthday-month');
  const birthdayDay = document.getElementById('birthday-day');
  const birthdayError = document.getElementById('birthday-error');
  const birthdayRow = document.getElementById('earning-birthday');
  const birthdayCheck = document.getElementById('birthday-check');

  // Check if birthday already saved (from localStorage)
  const birthdayKey = `birthday_saved:${emailFromQuery}`;
  if (localStorage.getItem(birthdayKey) === '1') {
    if (birthdayRow) birthdayRow.classList.add('claimed');
    if (birthdayCheck) birthdayCheck.textContent = '✓';
    if (birthdayBtn) {
      birthdayBtn.textContent = 'Saved';
      birthdayBtn.disabled = true;
      birthdayBtn.style.background = '#999';
      birthdayBtn.style.cursor = 'not-allowed';
    }
  }

  function openBirthdayModal() {
    if (birthdayModal) birthdayModal.classList.add('active');
    if (birthdayError) birthdayError.style.display = 'none';
  }

  function closeBirthdayModal() {
    if (birthdayModal) birthdayModal.classList.remove('active');
    if (birthdayMonth) birthdayMonth.value = '';
    if (birthdayDay) birthdayDay.value = '';
    if (birthdayError) birthdayError.style.display = 'none';
  }

  if (birthdayBtn) {
    birthdayBtn.addEventListener('click', openBirthdayModal);
  }

  if (birthdayClose) {
    birthdayClose.addEventListener('click', closeBirthdayModal);
  }

  if (birthdayCancel) {
    birthdayCancel.addEventListener('click', closeBirthdayModal);
  }

  if (birthdayModal) {
    birthdayModal.addEventListener('click', (e) => {
      if (e.target === birthdayModal) closeBirthdayModal();
    });
  }

  if (birthdaySave) {
    birthdaySave.addEventListener('click', async () => {
      const month = birthdayMonth?.value;
      const day = birthdayDay?.value;

      if (!month || !day) {
        if (birthdayError) {
          birthdayError.textContent = 'Please select your birth month and day.';
          birthdayError.style.display = 'block';
        }
        return;
      }

      const originalText = birthdaySave.textContent;
      birthdaySave.innerHTML = '<span class="loading-indicator"></span> Saving...';
      birthdaySave.disabled = true;

      try {
        const response = await fetch(`${apiBaseUrl}/api/referral/save-birthday`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: emailFromQuery, month, day })
        });

        const data = await response.json();

        if (response.ok) {
          localStorage.setItem(birthdayKey, '1');
          closeBirthdayModal();
          showNotification('Birthday saved! You\'ll receive 500 bonus points on your special day!');

          // Update UI
          if (birthdayRow) birthdayRow.classList.add('claimed');
          if (birthdayCheck) birthdayCheck.textContent = '✓';
          if (birthdayBtn) {
            birthdayBtn.textContent = 'Saved';
            birthdayBtn.disabled = true;
            birthdayBtn.style.background = '#999';
            birthdayBtn.style.cursor = 'not-allowed';
          }
        } else {
          if (birthdayError) {
            birthdayError.textContent = data.error || 'Error saving birthday.';
            birthdayError.style.display = 'block';
          }
          birthdaySave.textContent = originalText;
          birthdaySave.disabled = false;
        }
      } catch (err) {
        if (birthdayError) {
          birthdayError.textContent = 'Connection error. Please try again.';
          birthdayError.style.display = 'block';
        }
        birthdaySave.textContent = originalText;
        birthdaySave.disabled = false;
      }
    });
  }

});
