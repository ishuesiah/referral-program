    <h3 class="your-rewards-title">Your Rewards</h3>
    <div class="rewards-grid" id="rewards-grid">
      <!-- Rewards will be populated by JavaScript -->
    </div>
    <div class="no-rewards-message" id="no-rewards-message" style="display: none;">
      You haven't redeemed any rewards yet. Earn points and redeem them below!
    </div>
  </section>

<div class="redeem-wrap">
  <br>You have <span id="points-display-redeem">0</span> points available. Choose a reward below!
  
  <div class="scrollable-with-controls">
    <scroll-carousel
      selector=".redeem-options > *"
      id="scroll-area-redeem"
      class="scroll-area bleed {% if 5 > 3 %}is-scrollable{% endif %}"
    >
      <div class="redeem-options">
        {% assign redemptionOptions = "5:500,10:1000,20:2000,30:3000" | split: "," %}
        {% for option in redemptionOptions %}
          {% assign parts = option | split: ":" %}
          <div class="redeem-option carousel-item">
            <b>{{ parts[0] }} CAD off coupon</b>
            <p>{{ parts[1] }} Points</p>
            <button class="redeem-discount" data-points="{{ parts[1] }}" data-value="{{ parts[0] }}CAD">Redeem</button>
          </div>
        {% endfor %}
      </div>
    </scroll-carousel>
    
    {%- assign items_visible = 3 -%}
    {%- assign total_items = 5 -%}
    {%- assign default_progress = items_visible | times: 1.0 | divided_by: total_items -%}
    {%- render 'scrollbar', observes: 'scroll-area-redeem', default_progress: default_progress, show_buttons: false -%}
  </div>
  <div class="ref-hidden">
  <button id="redeem-another" style="display:none;">Redeem Another</button>
  <p id="last-discount-code"></p>
  <div id="redeem-message"></div> </div>
</div>

<!-- ===================== H&O TIERS (Dynamic Blocks) ===================== -->
{%- assign tier_blocks = section.blocks | where: "type", "tier" -%}

{%- if tier_blocks.size > 0 -%}
  <section class="tiers-wrap" aria-labelledby="tiers-heading">
    <h6 id="tiers-heading" class="tiers-title">
      {{ section.settings.tiers_heading | escape }}
    </h6>

    <div class="tiers-grid">
      {%- for block in tier_blocks -%}
        <div class="tier-card" {{ block.shopify_attributes }}>
          <div class="tier-top">
            <div class="tier-icon">
              {%- if block.settings.icon != blank -%}
                <img
                  src="{{ block.settings.icon | image_url: width: 160 }}"
                  alt="{{ block.settings.name | escape }} tier"
                  loading="lazy"
                >
              {%- else -%}
                <!-- Fallback: simple circle -->
                <svg viewBox="0 0 64 64" width="74" height="74" aria-hidden="true">
                  <circle cx="32" cy="32" r="22" fill="#ddd"></circle>
                </svg>
              {%- endif -%}
            </div>

            <div class="tier-name">{{ block.settings.name | escape }}</div>

            {%- if block.settings.subtitle != blank -%}
              <p class="tier-sub">{{ block.settings.subtitle | escape }}</p>
            {%- endif -%}
          </div>

          <div class="tier-band">
            {{ block.settings.points_per_dollar | escape }}
          </div>

          <div class="tier-body">
            {%- if block.settings.perks != blank -%}
              {%- assign perks = block.settings.perks | newline_to_br | split: "<br />" -%}
              <ul class="tier-perks">
                {%- for perk in perks -%}
                  {%- assign p = perk | strip -%}
                  {%- if p != blank -%}
                    <li>{{ p }}</li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

